[Unit]
Description=PetSafe API
After=network.target postgresql.service
Wants=network.target

[Service]
Type=simple
User=deploy
WorkingDirectory=/home/deploy/petsafe-backend
Environment=NODE_ENV=production
EnvironmentFile=/home/deploy/petsafe-backend/.env
ExecStart=/home/deploy/.nvm/versions/node/v22.22.0/bin/node dist/main.js
Restart=always
RestartSec=5
KillSignal=SIGINT
SyslogIdentifier=petsafe-api

[Install]
WantedBy=multi-user.target
