          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{mvzToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"vaccineId\": 999999,\n  \"applicationDate\": \"2026-03-29\"\n}" },
            "url": { "raw": "{{baseUrl}}/encounters/{{encounterId}}/vaccinations", "host": ["{{baseUrl}}"], "path": ["encounters","{{encounterId}}","vaccinations"] }
          }
        },

        {
          "name": "✅ Registrar desparasitación",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{mvzToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"productId\": 1,\n  \"applicationDate\": \"2026-03-29\",\n  \"suggestedNextDate\": \"2026-06-29\",\n  \"notes\": \"Desparasitación trimestral interna\"\n}" },
            "url": { "raw": "{{baseUrl}}/encounters/{{encounterId}}/dewormings", "host": ["{{baseUrl}}"], "path": ["encounters","{{encounterId}}","dewormings"] }
          }
        },

        {
          "name": "✅ Registrar tratamiento (con ítems)",
          "request": {
