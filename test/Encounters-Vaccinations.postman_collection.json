          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{mvzToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"requiresFollowUp\": true\n}" },
            "url": { "raw": "{{baseUrl}}/encounters/{{encounterId}}/plan", "host": ["{{baseUrl}}"], "path": ["encounters","{{encounterId}}","plan"] }
          }
        },

