{
  "info": {
    "name": "PetSafe — Cola complemento endpoints faltantes",
    "description": "Pruebas complementarias para endpoints no cubiertos en la colección de cola: detalle, finalizar atención y búsqueda por atención inexistente.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "const envBaseUrl = pm.environment.get('baseUrl') || pm.environment.get('base_url');",
          "if (envBaseUrl) {",
          "  pm.collectionVariables.set('baseUrl', envBaseUrl);",
          "  pm.collectionVariables.set('base_url', envBaseUrl);",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "base_url",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "adminEmail",
      "value": "admin@safepet.com"
    },
    {
      "key": "adminPassword",
      "value": "Admin123!"
    },
    {
      "key": "clientEmail",
      "value": "cliente@safepet.com"
    },
    {
      "key": "clientPassword",
      "value": "Cliente123!"
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "clientToken",
      "value": ""
    },
    {
      "key": "patientId",
      "value": "1"
    },
    {
      "key": "queueEntryId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "🔐 Setup",
      "item": [
        {
          "name": "✅ Login — admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login exitoso', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if ([200, 201].includes(pm.response.code)) {",
                  "  const body = pm.response.json();",
                  "  pm.test('La respuesta contiene accessToken', function () {",
                  "    pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
                  "  });",
                  "  pm.collectionVariables.set('adminToken', body.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "🏥 Cola — detalle y cierre",
      "item": [
        {
          "name": "✅ Crear entrada de cola para cierre",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status esperado (200 o 201 o 400)', function () {",
                  "  pm.expect([200, 201, 400]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const body = pm.response.json();",
                  "  const paths = [\"id\"];",
                  "  const read = (obj, path) => path.split(\".\").reduce((acc, key) => acc && acc[key], obj);",
                  "  let value;",
                  "  for (const path of paths) {",
                  "    value = read(body, path);",
                  "    if (value !== undefined && value !== null && value !== \"\") break;",
                  "  }",
                  "  if (value !== undefined && value !== null && value !== \"\") {",
                  "    pm.collectionVariables.set('queueEntryId', value);",
                  "    pm.test('queueEntryId capturado', () => pm.expect(String(value)).to.not.equal(''));",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": {{patientId}},\n  \"entryType\": \"SIN_CITA\",\n  \"notes\": \"Entrada generada para probar cierre desde Postman\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/queue",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "queue"
              ]
            }
          }
        },
        {
          "name": "✅ Obtener entrada por ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status esperado (200 o 404)', function () {",
                  "  pm.expect([200, 404]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/queue/{{queueEntryId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "queue",
                "{{queueEntryId}}"
              ]
            }
          }
        },
        {
          "name": "✅ Iniciar atención",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status esperado (200 o 400 o 404)', function () {",
                  "  pm.expect([200, 400, 404]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/queue/{{queueEntryId}}/start",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "queue",
                "{{queueEntryId}}",
                "start"
              ]
            }
          }
        },
        {
          "name": "✅ Finalizar atención",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status esperado (200 o 400 o 404)', function () {",
                  "  pm.expect([200, 400, 404]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/queue/{{queueEntryId}}/finish",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "queue",
                "{{queueEntryId}}",
                "finish"
              ]
            }
          }
        },
        {
          "name": "❌ Buscar cola por atención inexistente",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status esperado (404)', function () {",
                  "  pm.expect([404]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/queue/by-encounter/999999",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "queue",
                "by-encounter",
                "999999"
              ]
            }
          }
        }
      ]
    }
  ]
}
