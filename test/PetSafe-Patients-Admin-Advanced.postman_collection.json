{
  "info": {
    "name": "PetSafe — Pacientes Administración Avanzada",
    "description": "Pruebas de integración para los endpoints administrativos de pacientes no cubiertos previamente: creación sin tutor, historial del cliente, gestión de co-tutores (agregar/remover/establecer principal) e inicialización y actualización de planes de vacunación.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "adminEmail", "value": "admin@safepet.com" },
    { "key": "adminPassword", "value": "Admin123!" },
    { "key": "clienteEmail", "value": "cliente@safepet.com" },
    { "key": "clientePassword", "value": "Cliente123!" },
    { "key": "adminToken", "value": "" },
    { "key": "clienteToken", "value": "" },
    { "key": "speciesId", "value": "1", "description": "ID de especie (Canino). Ajustar según seed." },
    { "key": "breedId", "value": "1", "description": "ID de raza. Ajustar según seed." },
    { "key": "clientId1", "value": "1", "description": "ID de primer tutor/cliente existente" },
    { "key": "clientId2", "value": "2", "description": "ID de segundo tutor/cliente existente para co-tutela" },
    { "key": "schemeVersionId", "value": "1", "description": "ID de versión de esquema de vacunación. Ajustar según seed." },
    { "key": "patientWithoutTutorId", "value": "", "description": "ID de paciente creado sin tutor" },
    { "key": "patientWithTutorId", "value": "1", "description": "ID de paciente existente con tutor para pruebas de co-tutela" }
  ],
  "item": [
    {
      "name": "🔐 Setup",
      "item": [
        {
          "name": "✅ Login — admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login exitoso', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "if ([200, 201].includes(pm.response.code)) {",
                  "  pm.collectionVariables.set('adminToken', pm.response.json().accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "✅ Login — cliente",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login exitoso', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "if ([200, 201].includes(pm.response.code)) {",
                  "  pm.collectionVariables.set('clienteToken', pm.response.json().accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{clienteEmail}}\",\n  \"password\": \"{{clientePassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "🐾 Crear Paciente Sin Tutor",
      "description": "POST /patients/admin/without-tutor — Flujo administrativo para mascotas rescatadas o sin propietario inicial.",
      "item": [
        {
          "name": "✅ Crear paciente sin tutor (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('patientWithoutTutorId', body.id);",
                  "  pm.test('ID capturado', function () {",
                  "    pm.expect(body.id).to.be.a('number');",
                  "  });",
                  "  pm.test('Nombre correcto', function () {",
                  "    pm.expect(body.name).to.include('Rex Rescatado');",
                  "  });",
                  "  pm.test('No tiene tutor asignado', function () {",
                  "    const tutors = body.tutors || body.clients || [];",
                  "    pm.expect(tutors.length).to.eql(0);",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Rex Rescatado (Integration Test)", "type": "text" },
                { "key": "speciesId", "value": "{{speciesId}}", "type": "text" },
                { "key": "breedId", "value": "{{breedId}}", "type": "text" },
                { "key": "gender", "value": "MACHO", "type": "text" },
                { "key": "birthDate", "value": "2023-01-01", "type": "text" },
                { "key": "notes", "value": "Mascota rescatada sin propietario identificado", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/patients/admin/without-tutor",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "admin", "without-tutor"]
            }
          }
        },
        {
          "name": "❌ Crear paciente sin tutor — falta nombre (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 — nombre requerido', function () {",
                  "  pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "speciesId", "value": "{{speciesId}}", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/patients/admin/without-tutor",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "admin", "without-tutor"]
            }
          }
        },
        {
          "name": "❌ Crear paciente sin tutor — rol CLIENTE_APP (403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 — cliente no puede usar esta ruta', function () {",
                  "  pm.response.to.have.status(403);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clienteToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Test", "type": "text" },
                { "key": "speciesId", "value": "{{speciesId}}", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/patients/admin/without-tutor",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "admin", "without-tutor"]
            }
          }
        }
      ]
    },
    {
      "name": "📋 Historial Simplificado del Cliente",
      "description": "GET /patients/:id/client-history — Vista reducida de historial para la app del cliente (diferente al historial completo del veterinario).",
      "item": [
        {
          "name": "✅ Cliente ve historial simplificado de su mascota",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Historial es objeto con secciones básicas', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.be.an('object');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{clienteToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientWithTutorId}}/client-history",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientWithTutorId}}", "client-history"]
            }
          }
        },
        {
          "name": "❌ Cliente ve historial de mascota ajena (403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 — no puede ver mascota ajena', function () {",
                  "  pm.response.to.have.status(403);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{clienteToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/patients/999999/client-history",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "999999", "client-history"]
            }
          }
        },
        {
          "name": "❌ Admin intenta usar ruta de cliente (403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 — admin no tiene rol CLIENTE_APP', function () {",
                  "  pm.response.to.have.status(403);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientWithTutorId}}/client-history",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientWithTutorId}}", "client-history"]
            }
          }
        }
      ]
    },
    {
      "name": "👥 Gestión de Co-Tutores",
      "description": "Agregar, asignar como principal y remover tutores adicionales de una mascota.",
      "item": [
        {
          "name": "✅ Agregar co-tutor a la mascota",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 o 201', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Co-tutor agregado', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.be.an('object');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientId\": {{clientId2}},\n  \"isPrimary\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientWithTutorId}}/tutors",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientWithTutorId}}", "tutors"]
            }
          }
        },
        {
          "name": "❌ Agregar co-tutor — clientId inexistente (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 — cliente no existe', function () {",
                  "  pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientId\": 999999,\n  \"isPrimary\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientWithTutorId}}/tutors",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientWithTutorId}}", "tutors"]
            }
          }
        },
        {
          "name": "✅ Establecer co-tutor como tutor principal",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Tutor principal actualizado', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.be.an('object');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientWithTutorId}}/tutors/{{clientId2}}/primary",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientWithTutorId}}", "tutors", "{{clientId2}}", "primary"]
            }
          }
        },
        {
          "name": "❌ Establecer tutor principal — no es tutor de la mascota (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 — no es tutor de esta mascota', function () {",
                  "  pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientWithTutorId}}/tutors/999999/primary",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientWithTutorId}}", "tutors", "999999", "primary"]
            }
          }
        },
        {
          "name": "✅ Remover co-tutor de la mascota",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 o 204 — tutor removido', function () {",
                  "  pm.expect([200, 204]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientWithTutorId}}/tutors/{{clientId2}}",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientWithTutorId}}", "tutors", "{{clientId2}}"]
            }
          }
        },
        {
          "name": "❌ Remover tutor principal (único) — debe fallar (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 — no se puede remover el único tutor', function () {",
                  "  pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientWithTutorId}}/tutors/{{clientId1}}",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientWithTutorId}}", "tutors", "{{clientId1}}"]
            }
          }
        }
      ]
    },
    {
      "name": "💉 Plan de Vacunación del Paciente",
      "description": "Inicializar plan de vacunación basado en un esquema y actualizar el esquema asignado.",
      "item": [
        {
          "name": "✅ Inicializar plan de vacunación del paciente",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Plan inicializado con dosis', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.doses || body.planDoses || body.items).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schemeVersionId\": {{schemeVersionId}},\n  \"startDate\": \"2026-05-24\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientWithoutTutorId}}/vaccination-plan",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientWithoutTutorId}}", "vaccination-plan"]
            }
          }
        },
        {
          "name": "❌ Inicializar plan — versión de esquema inexistente (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', function () { pm.response.to.have.status(404); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schemeVersionId\": 999999,\n  \"startDate\": \"2026-05-24\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientWithoutTutorId}}/vaccination-plan",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientWithoutTutorId}}", "vaccination-plan"]
            }
          }
        },
        {
          "name": "❌ Inicializar plan — rol CLIENTE_APP (403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 — cliente no puede inicializar plan', function () {",
                  "  pm.response.to.have.status(403);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{clienteToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schemeVersionId\": {{schemeVersionId}},\n  \"startDate\": \"2026-05-24\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientWithTutorId}}/vaccination-plan",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientWithTutorId}}", "vaccination-plan"]
            }
          }
        },
        {
          "name": "✅ Actualizar esquema de vacunación del paciente",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Esquema actualizado', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.be.an('object');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schemeVersionId\": {{schemeVersionId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientWithoutTutorId}}/vaccination-scheme",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientWithoutTutorId}}", "vaccination-scheme"]
            }
          }
        },
        {
          "name": "✅ Actualizar campos básicos admin del paciente sin tutor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Datos actualizados', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.id).to.eql(parseInt(pm.collectionVariables.get('patientWithoutTutorId')));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Rex Rescatado (Actualizado)", "type": "text" },
                { "key": "weight", "value": "12.5", "type": "text" },
                { "key": "notes", "value": "Mascota en proceso de adopción", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/patients/admin/{{patientWithoutTutorId}}/basic",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "admin", "{{patientWithoutTutorId}}", "basic"]
            }
          }
        }
      ]
    }
  ]
}
