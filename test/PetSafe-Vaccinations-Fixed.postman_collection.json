    {
      "name": "🐾 Carnet de Vacunación del Paciente",
      "description": "Ruta correcta: /vaccinations/patients/:id/applications (no /records). Incluye listar y registrar aplicaciones.",
      "item": [
        {
          "name": "✅ Registrar aplicación de vacuna (externa)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Aplicación registrada', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.id).to.be.a('number');",
                  "  pm.expect(body.source || body.type).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vaccineId\": {{vaccineId}},\n  \"appliedAt\": \"2026-01-15\",\n  \"batchNumber\": \"LOTE-001-2026\",\n  \"nextDoseDate\": \"2027-01-15\",\n  \"notes\": \"Vacuna aplicada externamente antes de registrarse en la clínica\",\n  \"source\": \"EXTERNA\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/vaccinations/patients/{{patientId}}/applications",
              "host": ["{{baseUrl}}"],
              "path": ["vaccinations", "patients", "{{patientId}}", "applications"]
            }
          }
        },
        {
          "name": "✅ Registrar aplicación ligada a una atención",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
