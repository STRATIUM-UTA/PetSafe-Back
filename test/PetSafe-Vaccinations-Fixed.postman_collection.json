{
  "info": {
    "name": "PetSafe — Vacunación (Corregida y Completa)",
    "description": "Colección CORREGIDA de pruebas de integración para el módulo de Vacunación. Se actualizaron las rutas obsoletas: /catalog→/products, /scheme→/schemes, /records→/applications. Incluye flujos de catálogo de vacunas (productos), esquemas de vacunación, carnet del paciente y gestión de dosis del plan.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "adminEmail", "value": "admin@safepet.com" },
    { "key": "adminPassword", "value": "Admin123!" },
    { "key": "adminToken", "value": "" },
    { "key": "speciesId", "value": "1", "description": "ID de especie (ej: Canino). Ajustar según seed." },
    { "key": "vaccineId", "value": "", "description": "ID del producto vacuna creada en la prueba" },
    { "key": "vaccineIdForDelete", "value": "", "description": "ID de vacuna sin aplicaciones para probar eliminación limpia" },
    { "key": "patientId", "value": "1", "description": "ID de paciente existente con especie registrada" },
    { "key": "encounterId", "value": "1", "description": "ID de atención existente para registrar vacunación ligada" },
    { "key": "schemeId", "value": "", "description": "ID de esquema de vacunación creado" },
    { "key": "schemeVersionId", "value": "", "description": "ID de versión del esquema creada" },
    { "key": "patientPlanDoseId", "value": "", "description": "ID de dosis del plan del paciente" }
  ],
  "item": [
    {
      "name": "🔐 Setup — Login",
      "item": [
        {
          "name": "✅ Login — admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login exitoso', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "if ([200, 201].includes(pm.response.code)) {",
                  "  const body = pm.response.json();",
                  "  pm.test('La respuesta contiene accessToken', function () {",
                  "    pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
                  "  });",
                  "  pm.collectionVariables.set('adminToken', body.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
