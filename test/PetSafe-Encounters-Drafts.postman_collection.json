              "raw": "{{baseUrl}}/encounters/{{encounterId}}/vaccination-drafts/{{vaccinationDraftId}}",
              "host": ["{{baseUrl}}"],
              "path": ["encounters", "{{encounterId}}", "vaccination-drafts", "{{vaccinationDraftId}}"]
            }
          }
        },
        {
          "name": "❌ Crear borrador — vaccineId inexistente (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 — vacuna no existe', function () {",
                  "  pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vaccineId\": 999999,\n  \"appliedAt\": \"2026-05-24\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/encounters/{{encounterId}}/vaccination-drafts",
              "host": ["{{baseUrl}}"],
              "path": ["encounters", "{{encounterId}}", "vaccination-drafts"]
            }
          }
        },
        {
          "name": "✅ Eliminar borrador de vacuna (soft delete)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 o 204 — borrador eliminado', function () {",
                  "  pm.expect([200, 204]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/encounters/{{encounterId}}/vaccination-drafts/{{vaccinationDraftId}}/delete",
              "host": ["{{baseUrl}}"],
              "path": ["encounters", "{{encounterId}}", "vaccination-drafts", "{{vaccinationDraftId}}", "delete"]
            }
          }
        },
        {
          "name": "❌ Eliminar borrador inexistente (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', function () { pm.response.to.have.status(404); });"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/encounters/{{encounterId}}/vaccination-drafts/999999/delete",
              "host": ["{{baseUrl}}"],
              "path": ["encounters", "{{encounterId}}", "vaccination-drafts", "999999", "delete"]
            }
          }
        }
      ]
    },
