{
  "info": {
    "name": "PetSafe — Encounters Borradores (Drafts)",
    "description": "Pruebas de integración para los endpoints de borradores en atenciones clínicas: vacunas borrador, tratamientos borrador, revisiones de tratamiento y procedimientos borrador. Todos estos endpoints permiten al MVZ guardar un estado parcial mientras construye la ficha clínica.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "adminEmail", "value": "admin@safepet.com" },
    { "key": "adminPassword", "value": "Admin123!" },
    { "key": "adminToken", "value": "" },
    { "key": "encounterId", "value": "1", "description": "ID de atención ABIERTA (estado EN_ATENCION). Ajustar según seed." },
    { "key": "patientId", "value": "1", "description": "ID de paciente para la atención" },
    { "key": "vaccineId", "value": "1", "description": "ID de vacuna del catálogo para el borrador" },
    { "key": "procedureCatalogId", "value": "1", "description": "ID del catálogo de procedimientos" },
    { "key": "vaccinationDraftId", "value": "", "description": "ID del borrador de vacuna creado" },
    { "key": "treatmentDraftId", "value": "", "description": "ID del borrador de tratamiento creado" },
    { "key": "treatmentReviewDraftId", "value": "", "description": "ID del borrador de revisión de tratamiento creado" },
    { "key": "procedureDraftId", "value": "", "description": "ID del borrador de procedimiento creado" }
  ],
  "item": [
    {
      "name": "🔐 Setup",
      "item": [
        {
          "name": "✅ Login — admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login exitoso', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "if ([200, 201].includes(pm.response.code)) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('adminToken', body.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "🔧 Crear atención para pruebas de borradores",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if ([200, 201].includes(pm.response.code)) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('encounterId', body.id);",
                  "  pm.test('Atención creada', function () {",
                  "    pm.expect(body.id).to.be.a('number');",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": {{patientId}},\n  \"startTime\": \"2026-05-24T10:00:00\",\n  \"reason\": \"Consulta de prueba para borradores\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/encounters",
              "host": ["{{baseUrl}}"],
              "path": ["encounters"]
            }
          }
        }
      ]
    },
    {
      "name": "💉 Borradores de Vacunas",
      "description": "POST /encounters/:id/vaccination-drafts — PUT — PATCH delete",
      "item": [
        {
          "name": "✅ Crear borrador de vacuna",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('vaccinationDraftId', body.id);",
                  "  pm.test('ID de borrador capturado', function () {",
                  "    pm.expect(body.id).to.be.a('number');",
                  "  });",
                  "  pm.test('Tiene vaccineId', function () {",
                  "    pm.expect(body.vaccineId || body.vaccine).to.exist;",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vaccineId\": {{vaccineId}},\n  \"batchNumber\": \"LOTE-DRAFT-001\",\n  \"appliedAt\": \"2026-05-24\",\n  \"nextDoseDate\": \"2027-05-24\",\n  \"notes\": \"Borrador de vacuna para prueba de integración\"\n}"
