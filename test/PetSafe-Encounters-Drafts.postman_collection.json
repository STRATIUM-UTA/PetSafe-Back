            }
          }
        },
        {
          "name": "✅ Reactivar atención (FINALIZADA → ABIERTA)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Atención reactivada', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.not.eql('FINALIZADA');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
