            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Borrador actualizado', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.id).to.eql(parseInt(pm.collectionVariables.get('vaccinationDraftId')));",
