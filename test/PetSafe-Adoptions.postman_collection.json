{
  "info": {
    "name": "PetSafe — Módulo de Adopción",
    "description": "Pruebas de integración para adopciones y tags de adopción: CRUD completo, catálogo, búsqueda y transiciones de estado.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "adminEmail",
      "value": "admin@safepet.com"
    },
    {
      "key": "adminPassword",
      "value": "Admin123!"
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "patientId",
      "value": "1",
      "description": "ID de paciente existente en seed"
    },
    {
      "key": "patientIdForDelete",
      "value": "2",
      "description": "ID de otro paciente para la adopción que se eliminará"
    },
    {
      "key": "adopterClientId",
      "value": "1",
      "description": "ID de cliente existente en seed para asignar como adoptante"
    },
    {
      "key": "tagId",
      "value": "",
      "description": "ID del tag creado en pruebas de tags"
    },
    {
      "key": "tagToDeleteId",
      "value": "",
      "description": "ID del tag creado para la prueba de eliminación"
    },
    {
      "key": "adoptionId",
      "value": "",
      "description": "ID de adopción principal, usada en get/update"
    },
    {
      "key": "adoptionToDeleteId",
      "value": "",
      "description": "ID de adopción creada para la prueba de eliminación"
    }
  ],
  "item": [
    {
      "name": "🔐 Setup",
      "item": [
        {
          "name": "✅ Login — admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('adminToken', body.accessToken);",
                  "  pm.test('Token capturado', function () {",
                  "    pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
