{
  "info": {
    "name": "PetSafe — Clientes Eliminación y Health Check",
    "description": "Colección que cubre los flujos faltantes: eliminación exitosa de clientes (DELETE /clients/:id que requiere rol ADMIN) y verificación del estado del sistema mediante el health check endpoint. Incluye validación de permisos por roles.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "adminEmail", "value": "admin@safepet.com" },
    { "key": "adminPassword", "value": "Admin123!" },
    { "key": "adminToken", "value": "" },
    { "key": "clienteEmail", "value": "cliente@safepet.com" },
    { "key": "clientePassword", "value": "Cliente123!" },
    { "key": "clienteToken", "value": "" },
    { "key": "clientToDeleteId", "value": "", "description": "ID del cliente creado para ser eliminado en la prueba" }
  ],
  "item": [
    {
      "name": "🔐 Setup",
      "item": [
        {
          "name": "✅ Login — admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login exitoso', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "if ([200, 201].includes(pm.response.code)) {",
                  "  pm.collectionVariables.set('adminToken', pm.response.json().accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "✅ Login — cliente",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login exitoso', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "if ([200, 201].includes(pm.response.code)) {",
                  "  pm.collectionVariables.set('clienteToken', pm.response.json().accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{clienteEmail}}\",\n  \"password\": \"{{clientePassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "🔧 Crear cliente para eliminar",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Cliente creado', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "if ([200, 201].includes(pm.response.code)) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('clientToDeleteId', body.id || body.clientId);",
                  "  pm.test('ID de cliente capturado', function () {",
                  "    pm.expect(body.id || body.clientId).to.be.a('number');",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Cliente\",\n  \"lastName\": \"ParaEliminar Integration\",\n  \"documentId\": \"9988776655\",\n  \"email\": \"para.eliminar.integration@test.com\",\n  \"phone\": \"555-9999\",\n  \"gender\": \"MASCULINO\",\n  \"birthDate\": \"1990-06-15\",\n  \"address\": \"Calle de Prueba 123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/clients",
              "host": ["{{baseUrl}}"],
              "path": ["clients"]
            }
          }
        }
      ]
    },
    {
      "name": "🗑️ Eliminación de Clientes",
      "description": "DELETE /clients/:id — Solo puede hacerlo el rol ADMIN. Soft delete (conserva el registro con deletedAt).",
      "item": [
        {
          "name": "❌ Eliminar cliente — rol CLIENTE_APP (403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 — cliente no puede eliminar clientes', function () {",
                  "  pm.response.to.have.status(403);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{clienteToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/clients/{{clientToDeleteId}}",
              "host": ["{{baseUrl}}"],
              "path": ["clients", "{{clientToDeleteId}}"]
            }
          }
        },
        {
          "name": "✅ Eliminar cliente — admin (soft delete exitoso)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 o 204 — cliente eliminado', function () {",
                  "  pm.expect([200, 204]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.test('Cliente eliminado (soft delete)', function () {",
                  "    pm.expect(body.deletedAt || body.activo === false || body.isActive === false).to.exist;",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/clients/{{clientToDeleteId}}",
              "host": ["{{baseUrl}}"],
              "path": ["clients", "{{clientToDeleteId}}"]
            }
          }
        },
        {
          "name": "❌ Obtener cliente eliminado — ya no está disponible (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 — cliente eliminado no se puede obtener', function () {",
                  "  pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/clients/{{clientToDeleteId}}",
              "host": ["{{baseUrl}}"],
              "path": ["clients", "{{clientToDeleteId}}"]
            }
          }
        },
        {
          "name": "❌ Eliminar el mismo cliente dos veces (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 — ya fue eliminado', function () {",
                  "  pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/clients/{{clientToDeleteId}}",
              "host": ["{{baseUrl}}"],
              "path": ["clients", "{{clientToDeleteId}}"]
            }
          }
        },
        {
          "name": "❌ Eliminar cliente — sin token (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', function () { pm.response.to.have.status(401); });"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/clients/1",
              "host": ["{{baseUrl}}"],
              "path": ["clients", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "💚 Health Check del Sistema",
      "description": "GET /health — Verifica que el servidor y sus dependencias (base de datos, etc.) están operativos.",
      "item": [
        {
          "name": "✅ Health check — sistema operativo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 — sistema operativo', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Respuesta válida del health check', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.be.an('object');",
                  "  const status = body.status || body.health || body.state;",
                  "  pm.expect(['ok', 'healthy', 'up', 'running']).to.include(status?.toLowerCase() || 'ok');",
                  "});",
                  "pm.test('Tiempo de respuesta menor a 2000ms', function () {",
                  "  pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          }
        },
        {
          "name": "✅ Health check — autenticado (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Health check funciona con token también', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.be.an('object');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          }
        }
      ]
    }
  ]
}
