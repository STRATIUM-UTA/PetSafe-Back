{
  "info": {
    "name": "PetSafe API",
    "_postman_id": "3b4c6a6a-3b98-4fbe-9f9b-6f2e25529c3b",
    "description": "Colección Postman para PetSafe (NestJS + TypeORM). Incluye auth, autogestión /me, clientes (backoffice + ownership), y pacientes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api", "type": "string" },

    { "key": "admin_email", "value": "admin@safepet.com", "type": "string" },
    { "key": "admin_password", "value": "Admin123!", "type": "string" },

    { "key": "client_email", "value": "cliente@safepet.com", "type": "string" },
    { "key": "client_password", "value": "Cliente123!", "type": "string" },

    { "key": "admin_token", "value": "", "type": "string" },
    { "key": "client_token", "value": "", "type": "string" },

    { "key": "cliente_id", "value": "", "type": "string" },
    { "key": "other_cliente_id", "value": "", "type": "string" },
    { "key": "paciente_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET / (Hello)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/register (nuevo cliente)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"nuevo+{{$timestamp}}@example.com\",\n  \"password\": \"Passw0rd!123\",\n  \"nombres\": \"Nuevo\",\n  \"apellidos\": \"Cliente\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.access_token) {",
                  "  pm.collectionVariables.set('client_token', json.access_token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/login (admin seeded)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.access_token) {",
                  "  pm.collectionVariables.set('admin_token', json.access_token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/login (cliente seeded)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"{{client_email}}\",\n  \"password\": \"{{client_password}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.access_token) {",
                  "  pm.collectionVariables.set('client_token', json.access_token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /auth/profile (token cliente)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "url": "{{baseUrl}}/auth/profile"
          }
        }
      ]
    },
    {
      "name": "Me (CLIENTE_APP)",
      "item": [
        {
          "name": "GET /me/profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "url": "{{baseUrl}}/me/profile"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.id) {",
                  "  pm.collectionVariables.set('cliente_id', json.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "PATCH /me/update (actualizar correo/telefono)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{client_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"telefono\": \"555-0001\",\n  \"correo\": \"cliente+{{$timestamp}}@example.com\"\n}"
            },
            "url": "{{baseUrl}}/me/update"
          }
        }
      ]
    },
    {
      "name": "Clientes (Backoffice)",
      "item": [
        {
          "name": "GET /clientes (paginado + filtros)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": {
              "raw": "{{baseUrl}}/clientes?page=1&limit=10&nombres=&cedula=&correo=&mascotaNombre=",
              "host": ["{{baseUrl}}"],
              "path": ["clientes"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "nombres", "value": "" },
                { "key": "cedula", "value": "" },
                { "key": "correo", "value": "" },
                { "key": "mascotaNombre", "value": "" }
              ]
            }
          }
        },
        {
          "name": "POST /clientes (crear cliente backoffice)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombres\": \"Carlos\",\n  \"apellidos\": \"Ramírez\",\n  \"cedula\": \"0102030405\",\n  \"telefono\": \"0999999999\",\n  \"direccion\": \"Av. Principal\",\n  \"observaciones\": \"Creado desde backoffice\"\n}"
            },
            "url": "{{baseUrl}}/clientes"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.id) {",
                  "  pm.collectionVariables.set('other_cliente_id', json.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /clientes/:id (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": "{{baseUrl}}/clientes/{{other_cliente_id}}"
          }
        },
        {
          "name": "PATCH /clientes/:id (admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"telefono\": \"0888888888\",\n  \"observaciones\": \"Actualizado\"\n}"
            },
            "url": "{{baseUrl}}/clientes/{{other_cliente_id}}"
          }
        },
        {
          "name": "DELETE /clientes/:id (admin soft-delete)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": "{{baseUrl}}/clientes/{{other_cliente_id}}"
          }
        }
      ]
    },
    {
      "name": "Clientes (Cliente ownership)",
      "item": [
        {
          "name": "GET /clientes (CLIENTE_APP → solo yo)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "url": "{{baseUrl}}/clientes?page=1&limit=10"
          }
        },
        {
          "name": "GET /clientes/:id (CLIENTE_APP → mi id)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "url": "{{baseUrl}}/clientes/{{cliente_id}}"
          }
        },
        {
          "name": "GET /clientes/:id (CLIENTE_APP → otro id, debe 403)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "url": "{{baseUrl}}/clientes/{{other_cliente_id}}"
          }
        }
      ]
    },
    {
      "name": "Pacientes",
      "item": [
        {
          "name": "POST /pacientes (CLIENTE_APP)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{client_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Firulais\",\n  \"especieId\": \"00000000-0000-0000-0000-000000000000\",\n  \"sexo\": \"MACHO\"\n}"
            },
            "url": "{{baseUrl}}/pacientes"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Nota: este endpoint requiere IDs reales de catálogo (especieId/razaId/colorId).",
                  "// Si tu BD ya tiene catálogos, reemplaza especieId en el body.",
                  "const json = pm.response.json();",
                  "if (json && json.id) {",
                  "  pm.collectionVariables.set('paciente_id', json.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /pacientes (CLIENTE_APP)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "url": "{{baseUrl}}/pacientes"
          }
        },
        {
          "name": "GET /pacientes/:id (CLIENTE_APP)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "url": "{{baseUrl}}/pacientes/{{paciente_id}}"
          }
        }
      ]
    }
  ]
}
