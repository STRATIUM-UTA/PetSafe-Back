{
  "info": {
    "name": "PetSafe — Solicitudes de cita (staff faltante)",
    "description": "Pruebas complementarias para endpoints de appointment-requests no cubiertos por la colección de notificaciones: listado staff, contador de pendientes y verificación de disponibilidad.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "const envBaseUrl = pm.environment.get('baseUrl') || pm.environment.get('base_url');",
          "if (envBaseUrl) {",
          "  pm.collectionVariables.set('baseUrl', envBaseUrl);",
          "  pm.collectionVariables.set('base_url', envBaseUrl);",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "base_url",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "adminEmail",
      "value": "admin@safepet.com"
    },
    {
      "key": "adminPassword",
      "value": "Admin123!"
    },
    {
      "key": "clientEmail",
      "value": "cliente@safepet.com"
    },
    {
      "key": "clientPassword",
      "value": "Cliente123!"
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "clientToken",
      "value": ""
    },
    {
      "key": "patientId",
      "value": "1"
    },
    {
      "key": "appointmentRequestId",
      "value": ""
    },
    {
      "key": "preferredDate",
      "value": "2026-06-15"
    },
    {
      "key": "preferredTime",
      "value": "10:30"
    }
  ],
  "item": [
    {
      "name": "🔐 Setup",
      "item": [
        {
          "name": "✅ Login — admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login exitoso', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if ([200, 201].includes(pm.response.code)) {",
                  "  const body = pm.response.json();",
                  "  pm.test('La respuesta contiene accessToken', function () {",
                  "    pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
                  "  });",
                  "  pm.collectionVariables.set('adminToken', body.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "✅ Login — cliente",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login exitoso', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if ([200, 201].includes(pm.response.code)) {",
                  "  const body = pm.response.json();",
                  "  pm.test('La respuesta contiene accessToken', function () {",
                  "    pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
                  "  });",
                  "  pm.collectionVariables.set('clientToken', body.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{clientEmail}}\",\n  \"password\": \"{{clientPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "📝 Flujo mínimo de solicitud",
      "item": [
        {
          "name": "✅ Cliente crea solicitud para datos de prueba",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status esperado (200 o 201)', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const body = pm.response.json();",
                  "  const paths = [\"id\"];",
                  "  const read = (obj, path) => path.split(\".\").reduce((acc, key) => acc && acc[key], obj);",
                  "  let value;",
                  "  for (const path of paths) {",
                  "    value = read(body, path);",
                  "    if (value !== undefined && value !== null && value !== \"\") break;",
                  "  }",
                  "  if (value !== undefined && value !== null && value !== \"\") {",
                  "    pm.collectionVariables.set('appointmentRequestId', value);",
                  "    pm.test('appointmentRequestId capturado', () => pm.expect(String(value)).to.not.equal(''));",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{clientToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": {{patientId}},\n  \"reason\": \"Control preventivo generado desde Postman\",\n  \"preferredDate\": \"{{preferredDate}}\",\n  \"preferredTime\": \"{{preferredTime}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/appointment-requests",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "appointment-requests"
              ]
            }
          }
        },
        {
          "name": "✅ Cliente lista sus solicitudes",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status esperado (200)', function () {",
                  "  pm.expect([200]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{clientToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/appointment-requests/my",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "appointment-requests",
                "my"
              ]
            }
          }
        },
        {
          "name": "✅ Staff lista todas las solicitudes",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status esperado (200)', function () {",
                  "  pm.expect([200]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/appointment-requests",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "appointment-requests"
              ]
            }
          }
        },
        {
          "name": "✅ Staff consulta pendientes",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status esperado (200)', function () {",
                  "  pm.expect([200]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Incluye count', () => pm.expect(pm.response.json()).to.have.property('count'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/appointment-requests/pending-count",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "appointment-requests",
                "pending-count"
              ]
            }
          }
        },
        {
          "name": "✅ Staff verifica disponibilidad",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status esperado (200)', function () {",
                  "  pm.expect([200]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Incluye available', () => pm.expect(pm.response.json()).to.have.property('available'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/appointment-requests/check-availability?date={{preferredDate}}&time={{preferredTime}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "appointment-requests",
                "check-availability"
              ],
              "query": [
                {
                  "key": "date",
                  "value": "{{preferredDate}}"
                },
                {
                  "key": "time",
                  "value": "{{preferredTime}}"
                }
              ]
            }
          }
        },
        {
          "name": "✅ Staff rechaza solicitud generada",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status esperado (200)', function () {",
                  "  pm.expect([200]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"RECHAZADA\",\n  \"staffNotes\": \"Solicitud cerrada por prueba automatizada Postman\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/appointment-requests/{{appointmentRequestId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "appointment-requests",
                "{{appointmentRequestId}}",
                "status"
              ]
            }
          }
        }
      ]
    }
  ]
}
