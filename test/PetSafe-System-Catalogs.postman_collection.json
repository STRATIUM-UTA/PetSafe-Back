                "exec": [
                  "pm.test('Status esperado (200)', function () {",
                  "  pm.expect([200]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Respuesta es objeto de enums', () => pm.expect(pm.response.json()).to.be.an('object'));"
                ]
