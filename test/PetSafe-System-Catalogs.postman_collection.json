{
  "info": {
    "name": "PetSafe — Sistema y Catálogos faltantes",
    "description": "Pruebas complementarias para módulos sin colección Postman dedicada: metadata, colors y catálogos de procedimientos/cirugías. No requiere configuración manual después de importar.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "const envBaseUrl = pm.environment.get('baseUrl') || pm.environment.get('base_url');",
          "if (envBaseUrl) {",
          "  pm.collectionVariables.set('baseUrl', envBaseUrl);",
          "  pm.collectionVariables.set('base_url', envBaseUrl);",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "base_url",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "adminEmail",
      "value": "admin@safepet.com"
    },
    {
      "key": "adminPassword",
      "value": "Admin123!"
    },
    {
      "key": "clientEmail",
      "value": "cliente@safepet.com"
    },
    {
      "key": "clientPassword",
      "value": "Cliente123!"
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "clientToken",
      "value": ""
    },
    {
      "key": "colorId",
      "value": ""
    },
    {
      "key": "procedureCatalogId",
      "value": ""
    },
    {
      "key": "surgeryCatalogId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "🔐 Setup",
      "item": [
        {
          "name": "✅ Login — admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login exitoso', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if ([200, 201].includes(pm.response.code)) {",
                  "  const body = pm.response.json();",
                  "  pm.test('La respuesta contiene accessToken', function () {",
                  "    pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
                  "  });",
                  "  pm.collectionVariables.set('adminToken', body.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "🧩 Metadata",
