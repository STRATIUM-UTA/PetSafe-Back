        {
          "name": "✅ Crear color",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status esperado (201)', function () {",
                  "  pm.expect([201]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const body = pm.response.json();",
                  "  const paths = [\"id\"];",
                  "  const read = (obj, path) => path.split(\".\").reduce((acc, key) => acc && acc[key], obj);",
                  "  let value;",
                  "  for (const path of paths) {",
                  "    value = read(body, path);",
                  "    if (value !== undefined && value !== null && value !== \"\") break;",
                  "  }",
                  "  if (value !== undefined && value !== null && value !== \"\") {",
                  "    pm.collectionVariables.set('colorId', value);",
                  "    pm.test('colorId capturado', () => pm.expect(String(value)).to.not.equal(''));",
                  "  }",
                  "}"
                ]
              }
            }
