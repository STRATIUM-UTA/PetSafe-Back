{
  "info": {
    "name": "PetSafe — Citas Inasistencias y Casos Clínicos Controles",
    "description": "Pruebas de integración para los flujos faltantes: marcado de inasistencias (PATCH /no-show) en el módulo de citas y agendamiento de consultas de control/seguimiento (POST /follow-ups) en el módulo de casos clínicos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "adminEmail", "value": "admin@safepet.com" },
    { "key": "adminPassword", "value": "Admin123!" },
    { "key": "adminToken", "value": "" },
    { "key": "patientId", "value": "1", "description": "ID de paciente existente para crear citas" },
    { "key": "appointmentId", "value": "", "description": "ID de cita creada para pruebas de inasistencia" },
    { "key": "appointmentForNoShowId", "value": "", "description": "ID de otra cita para marcar NO_SHOW" },
    { "key": "clinicalCaseId", "value": "1", "description": "ID de caso clínico existente. Ajustar según seed." },
    { "key": "appointmentDate", "value": "2026-12-01", "description": "Fecha futura para la cita de prueba" },
    { "key": "appointmentTime", "value": "10:00", "description": "Hora de la cita de prueba" }
  ],
  "item": [
    {
      "name": "🔐 Setup",
      "item": [
        {
          "name": "✅ Login — admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login exitoso', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "if ([200, 201].includes(pm.response.code)) {",
                  "  pm.collectionVariables.set('adminToken', pm.response.json().accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "🔧 Crear cita para probar inasistencia",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Cita creada', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "if ([200, 201].includes(pm.response.code)) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('appointmentForNoShowId', body.id);",
                  "  pm.test('ID capturado', function () {",
                  "    pm.expect(body.id).to.be.a('number');",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": {{patientId}},\n  \"scheduledDate\": \"{{appointmentDate}}\",\n  \"scheduledTime\": \"{{appointmentTime}}\",\n  \"endTime\": \"11:00\",\n  \"reason\": \"Control de rutina (prueba inasistencia)\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/appointments",
              "host": ["{{baseUrl}}"],
              "path": ["appointments"]
            }
          }
        }
      ]
    },
    {
      "name": "📵 Marcar Inasistencia (No-Show)",
      "description": "PATCH /appointments/:id/no-show — El paciente no asistió a la cita programada.",
      "item": [
        {
          "name": "✅ Marcar cita como inasistencia (NO_SHOW)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Estado cambia a NO_SHOW o equivalente', function () {",
                  "  const body = pm.response.json();",
                  "  const status = body.status || body.appointmentStatus || body.state;",
                  "  pm.expect(['NO_SHOW', 'INASISTENCIA', 'NO_ASISTIO']).to.include(status);",
                  "});",
                  "pm.test('ID coincide', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.id).to.eql(parseInt(pm.collectionVariables.get('appointmentForNoShowId')));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/appointments/{{appointmentForNoShowId}}/no-show",
              "host": ["{{baseUrl}}"],
              "path": ["appointments", "{{appointmentForNoShowId}}", "no-show"]
            }
          }
        },
        {
          "name": "❌ Marcar inasistencia — cita ya marcada como NO_SHOW (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 — ya marcada como inasistencia', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Mensaje de error presente', function () {",
                  "  pm.expect(pm.response.json().message).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/appointments/{{appointmentForNoShowId}}/no-show",
              "host": ["{{baseUrl}}"],
              "path": ["appointments", "{{appointmentForNoShowId}}", "no-show"]
            }
          }
        },
        {
          "name": "❌ Marcar inasistencia — cita inexistente (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', function () { pm.response.to.have.status(404); });"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/appointments/999999/no-show",
              "host": ["{{baseUrl}}"],
              "path": ["appointments", "999999", "no-show"]
            }
          }
        },
        {
          "name": "❌ Marcar inasistencia — sin token (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', function () { pm.response.to.have.status(401); });"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/appointments/{{appointmentForNoShowId}}/no-show",
              "host": ["{{baseUrl}}"],
              "path": ["appointments", "{{appointmentForNoShowId}}", "no-show"]
            }
          }
        }
      ]
    },
    {
      "name": "📅 Casos Clínicos — Controles de Seguimiento",
      "description": "POST /clinical-cases/:id/follow-ups — Agendar una consulta de control directamente desde un caso clínico abierto.",
      "item": [
        {
          "name": "✅ Agendar control de seguimiento para caso clínico",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Control agendado correctamente', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.id).to.be.a('number');",
                  "  pm.expect(body.scheduledDate || body.date || body.followUpDate).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"scheduledDate\": \"2026-07-01\",\n  \"scheduledTime\": \"09:00\",\n  \"endTime\": \"10:00\",\n  \"reason\": \"Control de seguimiento del caso clínico — revisión a 30 días\",\n  \"notes\": \"Verificar evolución del tratamiento dermatológico\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/clinical-cases/{{clinicalCaseId}}/follow-ups",
              "host": ["{{baseUrl}}"],
              "path": ["clinical-cases", "{{clinicalCaseId}}", "follow-ups"]
            }
          }
        },
        {
          "name": "❌ Agendar control — caso clínico inexistente (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', function () { pm.response.to.have.status(404); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"scheduledDate\": \"2026-07-01\",\n  \"scheduledTime\": \"09:00\",\n  \"endTime\": \"10:00\",\n  \"reason\": \"Control de seguimiento\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/clinical-cases/999999/follow-ups",
              "host": ["{{baseUrl}}"],
              "path": ["clinical-cases", "999999", "follow-ups"]
            }
          }
        },
        {
          "name": "❌ Agendar control — campos obligatorios faltantes (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 — campos obligatorios faltantes', function () {",
                  "  pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Solo notas, sin fecha\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/clinical-cases/{{clinicalCaseId}}/follow-ups",
              "host": ["{{baseUrl}}"],
              "path": ["clinical-cases", "{{clinicalCaseId}}", "follow-ups"]
            }
          }
        },
        {
          "name": "❌ Agendar control — sin token (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', function () { pm.response.to.have.status(401); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"scheduledDate\": \"2026-07-01\",\n  \"scheduledTime\": \"09:00\",\n  \"endTime\": \"10:00\",\n  \"reason\": \"Control\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/clinical-cases/{{clinicalCaseId}}/follow-ups",
              "host": ["{{baseUrl}}"],
              "path": ["clinical-cases", "{{clinicalCaseId}}", "follow-ups"]
            }
          }
        },
        {
          "name": "✅ Ver controles de seguimiento del caso clínico",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Respuesta es array con al menos un control', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(Array.isArray(body) || Array.isArray(body.data)).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/clinical-cases/{{clinicalCaseId}}/follow-ups",
              "host": ["{{baseUrl}}"],
              "path": ["clinical-cases", "{{clinicalCaseId}}", "follow-ups"]
            }
          }
        }
      ]
    }
  ]
}
