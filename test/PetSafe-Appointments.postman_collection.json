{
  "info": {
    "name": "PetSafe — Citas Agendadas",
    "description": "Pruebas de integración para el flujo de citas agendadas: crear turno, listar, registrar llegada y cancelar cita.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "adminEmail",
      "value": "admin@safepet.com"
    },
    {
      "key": "adminPassword",
      "value": "Admin123!"
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "patientId",
      "value": "1",
      "description": "ID de paciente existente en seed"
    },
    {
      "key": "appointmentId",
      "value": "",
      "description": "ID de cita creada en 'Crear Cita válida', reutilizada para Registrar Llegada"
    },
    {
      "key": "appointmentToCancelId",
      "value": "",
      "description": "ID de cita creada en 'Crear Cita para Cancelar'"
    }
  ],
  "item": [
    {
      "name": "🔐 Setup",
      "item": [
        {
          "name": "✅ Login — admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('adminToken', body.accessToken);",
                  "  pm.test('Token capturado', function () {",
                  "    pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "📝 Crear Turno",
      "item": [
        {
          "name": "✅ Crear cita válida",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('appointmentId', body.id);",
                  "  pm.test('ID de cita capturado', function () {",
                  "    pm.expect(body.id).to.be.a('number');",
                  "  });",
                  "  pm.test('Estado inicial PROGRAMADA', function () {",
                  "    pm.expect(body.status).to.eql('PROGRAMADA');",
                  "  });",
                  "  pm.test('PatientId coincide', function () {",
                  "    pm.expect(body.patientId).to.eql(parseInt(pm.collectionVariables.get('patientId')));",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": {{patientId}},\n  \"scheduledDate\": \"2026-05-15\",\n  \"scheduledTime\": \"09:00\",\n  \"endTime\": \"09:30\",\n  \"reason\": \"CONSULTA_GENERAL\",\n  \"notes\": \"Prueba de integración — cita válida\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/appointments",
              "host": ["{{baseUrl}}"],
              "path": ["appointments"]
            }
          }
        },
        {
          "name": "❌ Crear cita — sin patientId (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Mensaje de error presente', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"scheduledDate\": \"2026-05-15\",\n  \"scheduledTime\": \"10:00\",\n  \"endTime\": \"10:30\",\n  \"reason\": \"CONSULTA_GENERAL\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/appointments",
              "host": ["{{baseUrl}}"],
              "path": ["appointments"]
            }
          }
        },
        {
          "name": "❌ Crear cita — endTime antes de scheduledTime (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Mensaje de error presente', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": {{patientId}},\n  \"scheduledDate\": \"2026-05-15\",\n  \"scheduledTime\": \"11:30\",\n  \"endTime\": \"11:00\",\n  \"reason\": \"VACUNACION\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/appointments",
              "host": ["{{baseUrl}}"],
              "path": ["appointments"]
            }
          }
        },
        {
          "name": "❌ Crear cita — sin token (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', function () {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": {{patientId}},\n  \"scheduledDate\": \"2026-05-16\",\n  \"scheduledTime\": \"09:00\",\n  \"endTime\": \"09:30\",\n  \"reason\": \"CONTROL\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/appointments",
              "host": ["{{baseUrl}}"],
              "path": ["appointments"]
            }
          }
        },
        {
          "name": "❌ Crear cita — solapamiento de horario (409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409', function () {",
                  "  pm.response.to.have.status(409);",
                  "});",
                  "pm.test('Mensaje de conflicto presente', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "description": "Mismo veterinario, misma fecha y rango de hora que la cita creada en 'Crear cita válida'.",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": {{patientId}},\n  \"scheduledDate\": \"2026-05-15\",\n  \"scheduledTime\": \"09:00\",\n  \"endTime\": \"09:30\",\n  \"reason\": \"CONSULTA_GENERAL\",\n  \"notes\": \"Intento solapamiento\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/appointments",
              "host": ["{{baseUrl}}"],
              "path": ["appointments"]
            }
          }
        }
      ]
    },
    {
      "name": "📋 Listar Citas",
      "item": [
        {
          "name": "✅ Listar citas por rango de fechas",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Respuesta es array', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.be.an('array');",
                  "});",
                  "pm.test('Cita creada está en la lista', function () {",
                  "  const body = pm.response.json();",
                  "  const appointmentId = parseInt(pm.collectionVariables.get('appointmentId'));",
                  "  const found = body.some(a => a.id === appointmentId);",
                  "  pm.expect(found).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/appointments?from=2026-05-01&to=2026-05-31",
              "host": ["{{baseUrl}}"],
              "path": ["appointments"],
              "query": [
                { "key": "from", "value": "2026-05-01" },
                { "key": "to", "value": "2026-05-31" }
              ]
            }
          }
        },
        {
          "name": "❌ Listar citas — sin parámetro 'from' (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/appointments?to=2026-05-31",
              "host": ["{{baseUrl}}"],
              "path": ["appointments"],
              "query": [
                { "key": "to", "value": "2026-05-31" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "✅ Registrar Llegada",
      "description": "Confirma la cita (PROGRAMADA → CONFIRMADA). Requiere que 'appointmentId' esté seteado desde 'Crear cita válida'.",
      "item": [
        {
          "name": "✅ Confirmar cita (registrar llegada)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Estado cambia a CONFIRMADA', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('CONFIRMADA');",
                  "});",
                  "pm.test('ID coincide', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.id).to.eql(parseInt(pm.collectionVariables.get('appointmentId')));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/appointments/{{appointmentId}}/confirm",
              "host": ["{{baseUrl}}"],
              "path": ["appointments", "{{appointmentId}}", "confirm"]
            }
          }
        },
        {
          "name": "❌ Confirmar cita ya confirmada (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Mensaje de error presente', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "description": "Intenta confirmar la misma cita que ya fue confirmada en el paso anterior.",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/appointments/{{appointmentId}}/confirm",
              "host": ["{{baseUrl}}"],
              "path": ["appointments", "{{appointmentId}}", "confirm"]
            }
          }
        },
        {
          "name": "❌ Confirmar cita inexistente (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', function () {",
                  "  pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/appointments/999999/confirm",
              "host": ["{{baseUrl}}"],
              "path": ["appointments", "999999", "confirm"]
            }
          }
        }
      ]
    },
    {
      "name": "❌ Cancelar Cita",
      "description": "Crea una cita nueva para luego cancelarla. Independiente del flujo de Registrar Llegada.",
      "item": [
        {
          "name": "🔧 Crear cita para cancelar",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('appointmentToCancelId', body.id);",
                  "  pm.test('ID de cita a cancelar capturado', function () {",
                  "    pm.expect(body.id).to.be.a('number');",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "description": "Paso de setup para la prueba de cancelación. No es la prueba en sí.",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": {{patientId}},\n  \"scheduledDate\": \"2026-05-20\",\n  \"scheduledTime\": \"14:00\",\n  \"endTime\": \"14:30\",\n  \"reason\": \"TRATAMIENTO\",\n  \"notes\": \"Cita creada para prueba de cancelación\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/appointments",
              "host": ["{{baseUrl}}"],
              "path": ["appointments"]
            }
          }
        },
        {
          "name": "✅ Cancelar cita válida",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Estado cambia a CANCELADA', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('CANCELADA');",
                  "});",
                  "pm.test('ID coincide', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.id).to.eql(parseInt(pm.collectionVariables.get('appointmentToCancelId')));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/appointments/{{appointmentToCancelId}}/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["appointments", "{{appointmentToCancelId}}", "cancel"]
            }
          }
        },
        {
          "name": "❌ Cancelar cita ya cancelada (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Mensaje de error presente', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "description": "Intenta cancelar la misma cita que ya fue cancelada en el paso anterior.",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/appointments/{{appointmentToCancelId}}/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["appointments", "{{appointmentToCancelId}}", "cancel"]
            }
          }
        },
        {
          "name": "❌ Cancelar cita inexistente (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', function () {",
                  "  pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/appointments/999999/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["appointments", "999999", "cancel"]
            }
          }
        }
      ]
    }
  ]
}
