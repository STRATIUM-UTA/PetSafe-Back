{
  "info": {
    "name": "PetSafe — Flujo de Atención (Cola)",
    "description": "Pruebas de integración para el flujo de atención: listar cola del día, registrar ingreso, cancelar ingreso e iniciar atención.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "adminEmail",
      "value": "admin@safepet.com"
    },
    {
      "key": "adminPassword",
      "value": "Admin123!"
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "patientId",
      "value": "1",
      "description": "ID de paciente existente en seed"
    },
    {
      "key": "queueEntryId",
      "value": "",
      "description": "ID de entrada creada en 'Registrar ingreso válido', usada para Iniciar Atención"
    },
    {
      "key": "queueEntryToCancelId",
      "value": "",
      "description": "ID de entrada creada para prueba de cancelación"
    },
    {
      "key": "todayDate",
      "value": "2026-05-01",
      "description": "Fecha de hoy en formato YYYY-MM-DD"
    }
  ],
  "item": [
    {
      "name": "🔐 Setup",
      "item": [
        {
          "name": "✅ Login — admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('adminToken', body.accessToken);",
                  "  pm.test('Token capturado', function () {",
                  "    pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "📋 Listar Cola del Día",
      "item": [
        {
          "name": "✅ Listar cola — sin filtros (hoy)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Respuesta tiene data, meta y summary', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('data');",
                  "  pm.expect(body).to.have.property('meta');",
                  "  pm.expect(body).to.have.property('summary');",
                  "  pm.expect(body.data).to.be.an('array');",
                  "});",
                  "pm.test('Meta tiene campos de paginación', function () {",
                  "  const meta = pm.response.json().meta;",
                  "  pm.expect(meta).to.have.property('totalItems');",
                  "  pm.expect(meta).to.have.property('totalPages');",
                  "  pm.expect(meta).to.have.property('currentPage');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/queue",
              "host": ["{{baseUrl}}"],
              "path": ["queue"]
            }
          }
        },
        {
          "name": "✅ Listar cola — filtro por fecha",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Respuesta es válida', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/queue?date={{todayDate}}",
              "host": ["{{baseUrl}}"],
              "path": ["queue"],
              "query": [
                { "key": "date", "value": "{{todayDate}}" }
              ]
            }
          }
        },
        {
          "name": "✅ Listar cola — filtro por status EN_ESPERA",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Entradas son solo EN_ESPERA', function () {",
                  "  const body = pm.response.json();",
                  "  body.data.forEach(entry => {",
                  "    pm.expect(entry.queueStatus).to.eql('EN_ESPERA');",
                  "  });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/queue?status=EN_ESPERA",
              "host": ["{{baseUrl}}"],
              "path": ["queue"],
              "query": [
                { "key": "status", "value": "EN_ESPERA" }
              ]
            }
          }
        },
        {
          "name": "✅ Listar cola — paginación (page 1, limit 5)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Limit respetado', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data.length).to.be.at.most(5);",
                  "  pm.expect(body.meta.itemsPerPage).to.eql(5);",
                  "  pm.expect(body.meta.currentPage).to.eql(1);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/queue?page=1&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["queue"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "5" }
              ]
            }
          }
        },
        {
          "name": "❌ Listar cola — sin token (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', function () {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/queue",
              "host": ["{{baseUrl}}"],
              "path": ["queue"]
            }
          }
        }
      ]
    },
    {
      "name": "🏥 Registrar Ingreso",
      "item": [
        {
          "name": "✅ Registrar ingreso — sin cita (SIN_CITA)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('queueEntryId', body.id);",
                  "  pm.test('ID de entrada capturado', function () {",
                  "    pm.expect(body.id).to.be.a('number');",
                  "  });",
                  "  pm.test('Estado inicial EN_ESPERA', function () {",
                  "    pm.expect(body.queueStatus).to.eql('EN_ESPERA');",
                  "  });",
                  "  pm.test('Tipo de entrada SIN_CITA', function () {",
                  "    pm.expect(body.entryType).to.eql('SIN_CITA');",
                  "  });",
                  "  pm.test('Paciente coincide', function () {",
                  "    pm.expect(body.patient.id).to.eql(parseInt(pm.collectionVariables.get('patientId')));",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": {{patientId}},\n  \"entryType\": \"SIN_CITA\",\n  \"notes\": \"Prueba de integración — ingreso sin cita\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/queue",
              "host": ["{{baseUrl}}"],
              "path": ["queue"]
            }
          }
        },
        {
          "name": "❌ Registrar ingreso — paciente ya en cola hoy (409/400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rechaza duplicado (400 o 409)', function () {",
                  "  pm.expect([400, 409]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Mensaje de error presente', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "description": "El mismo paciente ya tiene entrada activa hoy (creada en el paso anterior).",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": {{patientId}},\n  \"entryType\": \"SIN_CITA\",\n  \"notes\": \"Intento de duplicado\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/queue",
              "host": ["{{baseUrl}}"],
              "path": ["queue"]
            }
          }
        },
        {
          "name": "❌ Registrar ingreso — sin patientId (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Mensaje de error presente', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entryType\": \"SIN_CITA\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/queue",
              "host": ["{{baseUrl}}"],
              "path": ["queue"]
            }
          }
        },
        {
          "name": "❌ Registrar ingreso — entryType inválido (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Mensaje de error presente', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": {{patientId}},\n  \"entryType\": \"TIPO_INVALIDO\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/queue",
              "host": ["{{baseUrl}}"],
              "path": ["queue"]
            }
          }
        },
        {
          "name": "✅ Registrar ingreso — emergencia",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Tipo EMERGENCIA', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.entryType).to.eql('EMERGENCIA');",
                  "});"
                ]
              }
            }
          ],
          "description": "Usa un patientId diferente. Ajustar si el seed no tiene otro paciente disponible.",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": 2,\n  \"entryType\": \"EMERGENCIA\",\n  \"notes\": \"Prueba de integración — ingreso emergencia\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/queue",
              "host": ["{{baseUrl}}"],
              "path": ["queue"]
            }
          }
        }
      ]
    },
    {
      "name": "❌ Cancelar Ingreso",
      "description": "Crea una entrada nueva para cancelarla. Independiente del flujo de Iniciar Atención.",
      "item": [
        {
          "name": "🔧 Crear entrada para cancelar",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('queueEntryToCancelId', body.id);",
                  "  pm.test('ID capturado', function () {",
                  "    pm.expect(body.id).to.be.a('number');",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "description": "Paso de setup. Usa patientId 3 — ajustar si no existe en seed.",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": 3,\n  \"entryType\": \"SIN_CITA\",\n  \"notes\": \"Entrada creada para prueba de cancelación\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/queue",
              "host": ["{{baseUrl}}"],
              "path": ["queue"]
            }
          }
        },
        {
          "name": "✅ Cancelar ingreso (EN_ESPERA → CANCELADA)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Estado cambia a CANCELADA', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.queueStatus).to.eql('CANCELADA');",
                  "});",
                  "pm.test('ID coincide', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.id).to.eql(parseInt(pm.collectionVariables.get('queueEntryToCancelId')));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/queue/{{queueEntryToCancelId}}/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["queue", "{{queueEntryToCancelId}}", "cancel"]
            }
          }
        },
        {
          "name": "❌ Cancelar ingreso ya cancelado (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Mensaje de error presente', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "description": "Intenta cancelar la misma entrada que ya fue cancelada.",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/queue/{{queueEntryToCancelId}}/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["queue", "{{queueEntryToCancelId}}", "cancel"]
            }
          }
        },
        {
          "name": "❌ Cancelar entrada inexistente (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', function () {",
                  "  pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/queue/999999/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["queue", "999999", "cancel"]
            }
          }
        }
      ]
    },
    {
      "name": "▶️ Iniciar Atención",
      "description": "Transiciona la entrada de EN_ESPERA → EN_ATENCION. Requiere queueEntryId de 'Registrar ingreso válido'.",
      "item": [
        {
          "name": "✅ Iniciar atención (EN_ESPERA → EN_ATENCION)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Estado cambia a EN_ATENCION', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.queueStatus).to.eql('EN_ATENCION');",
                  "});",
                  "pm.test('ID coincide', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.id).to.eql(parseInt(pm.collectionVariables.get('queueEntryId')));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/queue/{{queueEntryId}}/start",
              "host": ["{{baseUrl}}"],
              "path": ["queue", "{{queueEntryId}}", "start"]
            }
          }
        },
        {
          "name": "❌ Iniciar atención — entrada ya en EN_ATENCION (idempotente)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 (retorna como está)', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Estado sigue EN_ATENCION', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.queueStatus).to.eql('EN_ATENCION');",
                  "});"
                ]
              }
            }
          ],
          "description": "El servicio retorna la entrada tal como está si ya está EN_ATENCION.",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/queue/{{queueEntryId}}/start",
              "host": ["{{baseUrl}}"],
              "path": ["queue", "{{queueEntryId}}", "start"]
            }
          }
        },
        {
          "name": "❌ Iniciar atención — entrada cancelada (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Mensaje de error presente', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "description": "Usa queueEntryToCancelId que ya está en estado CANCELADA.",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/queue/{{queueEntryToCancelId}}/start",
              "host": ["{{baseUrl}}"],
              "path": ["queue", "{{queueEntryToCancelId}}", "start"]
            }
          }
        },
        {
          "name": "❌ Iniciar atención — entrada inexistente (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', function () {",
                  "  pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/queue/999999/start",
              "host": ["{{baseUrl}}"],
              "path": ["queue", "999999", "start"]
            }
          }
        }
      ]
    }
  ]
}
